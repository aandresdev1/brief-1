---
import Layout from '../../../layouts/Layout.astro';
import { PROJECT_TYPES, ICONS } from '../../../lib/projects.js';

const { id } = Astro.params;
const entries = Object.entries(PROJECT_TYPES);
---

<Layout step={1}>
  <div class="step">
    <h1>Cuéntanos sobre tu proyecto</h1>
    <p class="subtitle">Elige el tipo de proyecto que necesitas. Según tu selección, te haremos las preguntas correctas.</p>
    <div class="type-grid">
      {entries.map(([key, t]) => (
        <a
          class={`type-card ${t.available ? '' : 'disabled'}`}
          style={`--accent-color:${t.color}`}
          href={t.available ? `/brief/${id}/${key}` : undefined}
          aria-disabled={!t.available}
        >
          {!t.available && <span class="badge-soon">Próximamente</span>}
          <div class="type-icon" set:html={ICONS[key]}></div>
          <div class="type-label">{t.label}</div>
          <div class="type-hint">{t.hint}</div>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  a.type-card { text-decoration: none; display: block; }
  a.type-card.disabled { pointer-events: none; }
</style>
